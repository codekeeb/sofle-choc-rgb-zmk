#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/rgb_fx.h>

/ {
    behaviors {
        // Cicla la animacion de la OLED derecha (gema/gato/cabeza/astronauta)
        oledanim: oledanim {
            compatible = "zmk,behavior-oled-anim";
            #binding-cells = <0>;
        };

        // Encoders como controles RGB (giro horario = primera binding)
        rgbenc_m: rgbenc_m { // lower + encoder izq: modo
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgbfx RGBFX_NEXT(0)>, <&rgbfx RGBFX_PREVIOUS(0)>;
        };

        rgbenc_h: rgbenc_h { // lower + encoder der: tono
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgbfx RGBFX_HUE_UP(0)>, <&rgbfx RGBFX_HUE_DOWN(0)>;
        };

        rgbenc_b: rgbenc_b { // raise + encoder izq: brillo
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgbfx RGBFX_BRIGHTEN(0)>, <&rgbfx RGBFX_DIM(0)>;
        };

        rgbenc_s: rgbenc_s { // raise + encoder der: velocidad
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgbfx RGBFX_SPD_UP(0)>, <&rgbfx RGBFX_SPD_DOWN(0)>;
        };

        // Fast page scrolling encoder behavior - sends 20 page commands per rotation
        fast_pg_encoder: fast_pg_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&fast_pg_up>, <&fast_pg_dn>;
        };

        // Fast page up macro - sends 20 PG_UP commands
        fast_pg_up: fast_pg_up {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP &kp PG_UP>;
        };

        // Fast page down macro - sends 20 PG_DN commands
        fast_pg_dn: fast_pg_dn {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN &kp PG_DN>;
        };
    };
};

/* IMPORTANTE - NO BORRAR ESTE BLOQUE AUNQUE PAREZCA "DUPLICADO":
 * el shield sofle de ZMK (>= v0.3) trae su propio
 * boards/nice_nano_v2.overlay con MOSI en P0.06 y chain 36, y se aplica
 * DESPUES de config/boards/nice_nano_v2.overlay, pisandolo. El keymap es
 * lo ultimo que entra al devicetree, asi que solo desde aqui se puede
 * imponer el pin real de esta variante (P0.08) y la cadena de 30 LEDs.
 * (Ya paso una vez: se borro por "redundante" y los LEDs murieron durante
 * un dia entero de depuracion. Verificado leyendo PSEL.MOSI del SPIM3 en
 * caliente via USB logging.) */

#include <dt-bindings/led/led.h>

&pinctrl {
    spi3_default: spi3_default {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 8)>;
        };
    };

    spi3_sleep: spi3_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_MOSI, 0, 8)>;
            low-power-enable;
        };
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";

    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    pinctrl-names = "default", "sleep";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        label = "WS2812";

        /* SPI */
        reg = <0>; /* ignored, but necessary for SPI bindings */
        spi-max-frequency = <4000000>;

        /* WS2812: 30 por mitad (col interior 1-4, LED del encoder 5o,
         * pulgares y serpentina hasta la pinky) */
        chain-length = <30>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;

        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

/ {
    chosen {
        zmk,underglow = &led_strip;
    };
};

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "CODE";
// ------------------------------------------------------------------------------------------------------------------
// |  ESC  |  1  |  2  |  3   |  4   |  5   |                         |  6   |  7    |  8    |  9   |   0   |  DEL  |
// |  TAB  |  Q  |  W  |  E   |  R   |  T   |                         |  Y   |  U    |  I    |  O   |   P   | BKSPC |
// | SHIFT |  A  |  S  |  D   |  F   |  G   |                         |  H   |  J    |  K    |  L   |   ;   |   '   |
// |  CTRL |  Z  |  X  |  C   |  V   |  B   |  MUTE  |        | PLAY  |  N   |  M    |  ,    |  .   |   /   | SHIFT |
//               | GUI | ALT  | CTRL | LOWER|  SPACE |        | ENTER | RAISE| CTRL  | ALT   | GUI  |
            bindings = <
&kp ESC   &kp N1 &kp N2   &kp N3   &kp N4    &kp N5                              &kp N6 &kp N7    &kp N8    &kp N9   &kp N0   &kp DEL
&kp TAB   &kp Q  &kp W    &kp E    &kp R     &kp T                               &kp Y  &kp U     &kp I     &kp O    &kp P    &kp BSPC
&kp LSHFT &kp A  &kp S    &kp D    &kp F     &kp G                               &kp H  &kp J     &kp K     &kp L    &kp SEMI &kp SQT
&kp LCTRL &kp Z  &kp X    &kp C    &kp V     &kp B  &kp C_MUTE       &kp C_PLAY  &kp N  &kp M     &kp COMMA &kp DOT  &kp FSLH &kp RSHFT
                 &kp LGUI &kp LALT &kp LCTRL &mo 1  &kp RET          &kp SPACE   &mo 2  &kp RCTRL &kp RALT  &kp RGUI
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN &fast_pg_encoder>;
        };

        lower_layer {
            display-name = "Lower";
// TODO: Some binds are waiting for shifted keycode support.
// ------------------------------------------------------------------------------------------------------------
// |       | F1  | F2  |  F3  |  F4  |  F5  |                         |  F6  |   F7  |   F8  |  F9  |  F10  |  DEL  |
// | `     | F11 | F12 |   €  | RGB  |modRGB|                         |      |       |   UP  |      |       | BKSPC |
// |       |     |  {  |   }  | hue- | hue+ |                         |      | LEFT  |  DOWN | RIGHT|       |   |   |
// |       |ZMKSt|     |      | Bri- | Bri+ |        |        |       |      |       |       |      |   \   |       |
//               |     |      |      |      |  SPACE |        | ENTER |      |       |       |      |
            bindings = <
&trans     &kp F1         &kp F2       &kp F3       &kp F4                   &kp F5                                                         &kp F6     &kp F7     &kp F8           &kp F9     &kp F10    &kp DEL
&kp GRAVE  &kp F11        &kp F12      &kp RA(E)    &rgbfx RGBFX_TOGGLE(0)   &rgbfx RGBFX_NEXT(0)                                           &trans     &trans     &kp UP           &trans     &trans     &kp BSPC
&trans     &trans         &kp LBRC     &kp RBRC     &rgbfx RGBFX_HUE_DOWN(0) &rgbfx RGBFX_HUE_UP(0)                                         &trans     &kp LEFT   &kp DOWN         &kp RIGHT  &trans     &kp PIPE
&trans     &studio_unlock &trans       &trans       &rgbfx RGBFX_DIM(0)      &rgbfx RGBFX_BRIGHTEN(0)  &rgbfx RGBFX_TOGGLE(0)    &oledanim  &trans     &trans     &trans           &trans     &kp BSLH   &trans
                          &trans       &trans       &trans                   &trans                    &trans                    &trans     &trans     &trans     &trans           &trans
            >;

            sensor-bindings = <&rgbenc_m &rgbenc_h>;
        };

        raise_layer {
            display-name = "Rise";
// ------------------------------------------------------------------------------------------------------------
// |BTCLR| BT1  |  F2  |  F3   |  F4   |  F5  |                       |      |   [  |    ]  |   (  |   )   |  DEL  |
// |     |      |      |       |       |      |                       | PGUP |   7  |    8  |   9  |   %   | BKSPC |
// |     |      |      |       |       |      |                       | PGDN |   4  |    5  |   6  |   +   |   x   |
// |     | UNDO | CUT  | COPY  | PASTE |      |       |        |  RGB |      |   1  |    2  |   3  |   -   |   /   |
//              |      |       |       |      | SPACE |        | ENTER|      |   0  |    .  |   =  |
            bindings = <
&bt BT_CLR &bt BT_SEL 0 &kp F2       &kp F3       &kp F4       &kp F5                              &trans    &kp LBKT  &kp RBKT &kp LPAR  &kp RPAR      &kp DEL
&trans     &trans       &trans       &trans       &trans       &trans                              &kp PG_UP &kp N7    &kp N8   &kp N9    &kp PRCNT     &kp BSPC
&trans     &trans       &trans       &trans       &trans       &trans                              &kp PG_DN &kp N4    &kp N5   &kp N6    &kp KP_PLUS   &kp KP_MULTIPLY
&trans     &kp K_UNDO   &kp K_CUT    &kp K_COPY   &kp K_PASTE  &trans  &trans   &rgbfx RGBFX_TOGGLE(0)  &trans    &kp N1   &kp N2    &kp N3        &kp KP_MINUS  &kp KP_SLASH
                        &trans       &trans       &trans       &trans  &trans   &trans           &kp N0    &kp KP_DOT &kp KP_EQUAL &trans
            >;

            sensor-bindings = <&rgbenc_b &rgbenc_s>;
        };
    };
};